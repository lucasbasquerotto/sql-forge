  "query": "\n        SELECT items.id, items.name, items.price, items.stock\n        FROM items\n        JOIN categories ON categories.id = items.category_id\n        WHERE items.category_id = NULL\n        AND   items.price      >= NULL\n        ORDER BY items.created_at DESC LIMIT NULL OFFSET NULL\n        ",
